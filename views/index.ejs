<!DOCTYPE html>
<html lang="en" class="scroll-smooth cursor-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIzMiIgaGVpZ2h0PSIzMiI+PHRleHQgeT0iMjAiIGZpbGw9IiMwMDAwMDAiIGZvbnQtc2l6ZT0iMTYiIGZvbnQtd2VpZ2h0PSJib2xkIj4mbHQ7LyZndDs8L3RleHQ+PC9zdmc+'),_default]">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <title>LearnIt</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <nav class="relative z-50 bg-white shadow-lg">
        <!-- Main Navbar Row -->
        <div class="flex justify-between items-center px-7 h-21">
            <div class="text-base font-medium flex items-center gap-2">
                <img src="/favicon.ico" class="inline-block" alt="Logo"> LearnIt
            </div>

            <!-- Desktop Navigation Menu (Hidden on Mobile) -->
            <div class="hidden md:flex items-center text-base text-black btns">
                <a href="/" class="inline-block px-3 hover:text-zinc-800">Home</a>
                <a href="" class="inline-block px-3 hover:text-zinc-800">Cohort 1.0</a>
                <a href="" class="inline-block px-3 hover:text-zinc-800">Sign Up</a>
                <a href="" class="inline-block px-3">
                    <span class="bg-black text-white text-sm p-3 rounded-md hover:bg-zinc-800">Already In</span>
                </a>
            </div>

            <!-- Mobile Menu Toggle Button (Hidden on Desktop) -->
            <div class="flex md:hidden">
                <button id="menu-btn" type="button" class="text-black hover:text-zinc-800 focus:outline-none" aria-controls="mobile-menu" aria-expanded="false">
                    <span class="sr-only">Toggle main menu</span>
                    <!-- Hamburger Icon -->
                    <svg id="hamburger-icon" class="block h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                    </svg>
                    <!-- Close Icon -->
                    <svg id="close-icon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Dropdown Menu (Hidden by default, targets mobile screens only) -->
        <div id="mobile-menu" class="hidden md:hidden absolute top-21 left-0 w-full bg-white border-b border-zinc-200 shadow-md">
            <div class="flex flex-col space-y-3 px-7 pt-2 pb-6 text-base text-black">
                <a href="/" class="block py-2 hover:text-zinc-800 border-b border-zinc-100">Home</a>
                <a href="" class="block py-2 hover:text-zinc-800 border-b border-zinc-100">Cohort 1.0</a>
                <a href="" class="block py-2 hover:text-zinc-800 border-b border-zinc-100">Sign Up</a>
                <a href="" class="block pt-2">
                    <span class="block text-center bg-black text-white text-sm p-3 rounded-md hover:bg-zinc-800">Already In</span>
                </a>
            </div>
        </div>
    </nav>

    <div class="px-7 py-6">
        <h1 class="text-4xl font-bold">LearnIt</h1><br>
        <p class="text-zinc-500 pr-10 lg:pr-125 md:pr-50">LearnIt offers high-quality, comprehensive coding tutorials entirely for free. Master programming from scratch, build real-world projects, and launch your software engineering career today.</p>
        <a href="" class="inline-block mt-8"><span class="bg-black text-white text-sm p-3 rounded-md hover:bg-zinc-800">Already In</span></a>
        <a href="" class="inline-block mt-8"><span class="bg-transparent text-sm p-3 rounded-md border-2 border-zinc-800 hover:bg-stone-50">Sign Up</span></a>
    </div>

    <div class="px-7 py-6 mt-5">
        <img src="images/image1.jpg" alt="" class="w-full h-1/2">
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto p-6">
      <!-- Card 1: Web Development -->
      <div class="flex flex-col bg-white rounded-2xl shadow-md overflow-hidden border border-slate-100 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl group">
        <div class="relative h-48 w-full bg-slate-200 overflow-hidden">
          <img src="images/card/image3.png" alt="Web Development" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
        </div>
        <div class="flex flex-col flex-grow p-6">
          <h3 class="text-xl font-bold text-slate-800 mb-2">Web Development</h3>
          <p class="text-slate-600 text-sm flex-grow mb-6">Master HTML, CSS, JavaScript, and modern frameworks from absolute scratch. Build stunning responsive websites and deploy your live code.</p>
          <button class="w-full bg-blue-600 text-white font-medium py-2.5 px-4 rounded-xl transition-colors duration-200 hover:bg-blue-700">Start Coding</button>
        </div>
      </div>

      <!-- Card 2: Python Data Science -->
      <div class="flex flex-col bg-white rounded-2xl shadow-md overflow-hidden border border-slate-100 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl group">
        <div class="relative h-48 w-full bg-white overflow-hidden">
          <img src="images/card/image2.png" alt="Python Programming" class="w-full h-full object-contain transition-transform duration-300 group-hover:scale-105" />
        </div>
        <div class="flex flex-col flex-grow p-6">
          <h3 class="text-xl font-bold text-slate-800 mb-2">Python Fundamentals</h3>
          <p class="text-slate-600 text-sm flex-grow mb-6">Learn data structures, object-oriented concepts, and logic scripts using Python. Excellent layout baseline for future AI engineering fields.</p>
          <button class="w-full bg-blue-600 text-white font-medium py-2.5 px-4 rounded-xl transition-colors duration-200 hover:bg-blue-700">Start Learning</button>
        </div>
      </div>

      <!-- Card 3: UI/UX Essentials -->
      <div class="flex flex-col bg-white rounded-2xl shadow-md overflow-hidden border border-slate-100 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl group">
        <div class="relative h-48 w-full bg-zinc-900 overflow-hidden">
          <img src="images/card/image4.png" alt="UI/UX Design" class="w-full h-full object-contain transition-transform duration-300 group-hover:scale-105" />
        </div>
        <div class="flex flex-col flex-grow p-6">
          <h3 class="text-xl font-bold text-slate-800 mb-2">UI/UX Foundations</h3>
          <p class="text-slate-600 text-sm flex-grow mb-6">Discover wireframing, user-flow maps, visual layout design patterns, and interactive mockups that create amazing web experiences.</p>
          <button class="w-full bg-blue-600 text-white font-medium py-2.5 px-4 rounded-xl transition-colors duration-200 hover:bg-blue-700">Explore Design</button>
        </div>
      </div>
    </div>

    <!-- Script File Hook -->
    <script src="js/menu-1080.js"></script>
</body>
</html>
