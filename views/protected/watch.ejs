<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LearnIt - Watching: <%= video.title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/a90674.css">
</head>
<body class="bg-gray-50 text-gray-800 font-sans min-h-screen">

    <header class="border-b border-gray-200 bg-white sticky top-0 z-50 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <a href="/cohort" class="flex items-center gap-2 font-bold text-xl tracking-wider text-blue-600 hover:opacity-80 transition">
                <span>⬅️</span> Back to Dashboard
            </a>
            <div class="flex items-center gap-3">
                <span class="text-sm font-medium text-gray-600 hidden sm:inline"><%= user.fullname %></span>
                <div class="w-9 h-9 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-sm">
                    <%= user.fullname.charAt(0).toUpperCase() %>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <div class="lg:col-span-2 space-y-4">
                <div class="relative w-full aspect-video bg-black rounded-2xl overflow-hidden shadow-lg border border-gray-200">
                    <video 
                        class="w-full h-full object-contain" 
                        controls 
                        autoplay
                        poster="<%= video.thumbnail %>"
                    >
                        <source src="<%= video.videoPath %>" type="video/mp4">
                        <source src="<%= video.videoPath %>" type="video/webm">
                        Your browser does not support the video tag code playbacks.
                    </video>
                </div>

                <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm space-y-3">
                    <span class="inline-block px-2.5 py-0.5 bg-blue-50 text-blue-600 rounded text-xs font-bold uppercase tracking-wider">
                        <%= video.tag %>
                    </span>
                    <h1 class="text-xl sm:text-2xl font-extrabold text-gray-900 leading-snug">
                        <%= video.title %>
                    </h1>
                    
                    <div class="flex flex-wrap items-center justify-between gap-4 pt-3 border-t border-gray-100 text-sm text-gray-500 font-medium">
                        <div class="flex items-center gap-4">
                            <span>👁️ <%= video.views.length %> views</span>
                            <span>📅 Published <%= new Date(video.createdAt).toLocaleDateString(undefined, {year: 'numeric', month: 'long', day: 'numeric'}) %></span>
                        </div>
                        
                        <div class="flex items-center gap-2">
    <!-- Active state style condition check added for Likes -->
    <button id="like-btn" onclick="toggleLike('<%= video._id %>')" class="flex items-center gap-1.5 px-4 py-2 rounded-full transition text-sm font-semibold active:scale-95 <%= video.likes.includes(user._id) ? 'bg-blue-600 text-white hover:bg-blue-700' : 'bg-gray-100 hover:bg-gray-200 text-gray-700' %>">
        <span>👍</span> <span id="likes-count"><%= video.likes.length %></span> Likes
    </button>
    
    <button onclick="copyShareLink()" class="flex items-center gap-1.5 px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-full transition text-sm font-semibold text-gray-700 active:scale-95">
        <span>🔗</span> <span id="share-text">Share</span>
    </button>
</div>
                    </div>
                </div>
            </div>

            <div class="space-y-4">
                <h2 class="text-sm font-bold uppercase tracking-wider text-gray-400 mb-2 px-1">Other Cohort Tracks</h2>
                
                <div class="space-y-3">
                    <% if (suggestions && suggestions.length > 0) { %>
                        <% suggestions.forEach(track => { %>
                            <a href="/cohort/watch/<%= track._id %>" class="flex gap-3 bg-white p-2 rounded-xl border border-gray-200 shadow-sm hover:border-blue-300 hover:shadow-md transition group">
                                <div class="relative w-32 sm:w-40 aspect-video bg-gray-100 rounded-lg overflow-hidden flex-shrink-0">
                                    <img src="<%= track.thumbnail %>" alt="Thumbnail" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                                </div>
                                <div class="flex flex-col justify-between py-0.5 pr-1">
                                    <div>
                                        <h3 class="text-xs sm:text-sm font-bold text-gray-800 line-clamp-2 leading-tight group-hover:text-blue-600 transition">
                                            <%= track.title %>
                                        </h3>
                                        <span class="inline-block text-[10px] font-bold text-gray-400 mt-1 uppercase">
                                            <%= track.tag %>
                                        </span>
                                    </div>
                                    <span class="text-[11px] text-gray-400 font-medium mt-1">
                                        <%= track.views.length %> views
                                    </span>
                                </div>
                            </a>
                        <% }) %>
                    <% } else { %>
                        <div class="text-center py-8 bg-white rounded-xl border border-gray-200 text-sm text-gray-400">
                            No secondary tracks discovered.
                        </div>
                    <% } %>
                </div>
            </div>

        </div>
    </main>
    <script>
    // Asynchronous Database Interaction engine payload execution
    async function toggleLike(videoId) {
        const btn = document.getElementById('like-btn');
        const countSpan = document.getElementById('likes-count');

        try {
            const response = await fetch(`/cohort/video/${videoId}/like`, { method: 'POST' });
            const data = await response.json();

            if (data.success) {
                countSpan.innerText = data.likesCount;
                if (data.isLiked) {
                    btn.classList.remove('bg-gray-100', 'hover:bg-gray-200', 'text-gray-700');
                    btn.classList.add('bg-blue-600', 'text-white', 'hover:bg-blue-700');
                } else {
                    btn.classList.remove('bg-blue-600', 'text-white', 'hover:bg-blue-700');
                    btn.classList.add('bg-gray-100', 'hover:bg-gray-200', 'text-gray-700');
                }
            }
        } catch (err) {
            console.error('Like mutation framework network pipeline error:', err);
        }
    }

    // Modern Native Device Clipboard API String Push Interface
    function copyShareLink() {
        const shareText = document.getElementById('share-text');
        
        navigator.clipboard.writeText(window.location.href)
            .then(() => {
                shareText.innerText = "Copied!";
                setTimeout(() => {
                    shareText.innerText = "Share";
                }, 2500);
            })
            .catch(err => console.error('Error selecting text values:', err));
    }
</script>
</body>
</html>